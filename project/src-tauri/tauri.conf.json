{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OctoChat",
  "version": "0.1.0",
  "identifier": "com.hdx.octochat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OctoChat",
        "width": 1440,
        "height": 940,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
